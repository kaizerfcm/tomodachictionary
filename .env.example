# Optional: sync islands across devices (Supabase free tier).
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Web: Stripe Payment / Donate link (removes ads via webhook after checkout).
VITE_PAYMENT_URL_INTL=https://donate.stripe.com/28E8wQ3M29A2aC82hnbjW00

# Web only: show "Remove ads without paying" link (set false to hide).
VITE_ALLOW_FREE_AD_REMOVAL=true

# Android APK: copy .env.android → .env.android.local (see docs/ANDROID_BUILD.md).
# VITE_PLATFORM=android
# VITE_ADMOB_APP_ID=ca-app-pub-3940256099942544~3347511713
# VITE_ADMOB_BANNER_ID=ca-app-pub-3940256099942544/6300978111
# VITE_ADMOB_TESTING=true
