# Copy to .env.android.local for local Android builds (gitignored).
# Vite loads this via --mode android if you name it .env.android.local or merge into .env.android.

VITE_PLATFORM=android
VITE_ALLOW_FREE_AD_REMOVAL=false

# Required on device for auth + cloud save
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Must stay empty — Google Play billing, not Stripe
VITE_PAYMENT_URL_INTL=
